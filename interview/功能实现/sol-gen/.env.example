# Solana 网络配置
# 可选值: devnet | testnet | mainnet-beta
SOLANA_CLUSTER=devnet
# devnet: https://api.devnet.solana.com
# testnet: https://api.testnet.solana.com
# mainnet: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# 支付钱包的 64 字节密钥的 JSON 数组。请妥善保管此私密信息。
# 示例: [23,145,208, ... 62 more numbers ..., 82,19]
PAYER_SECRET_KEY=[]

# 接收生成代币的 Base58 公钥。
# 示例: 7xKX...（Base58 编码的公钥地址）
RECIPIENT_PUBLIC_KEY=

# 代币设置
# 代币小数位数（大多数 SPL 代币为 9，类似 SOL 的精度）
TOKEN_DECIMALS=9
# 铸造数量（按最小单位计，实际数量 = TOKEN_AMOUNT / 10^TOKEN_DECIMALS）
TOKEN_AMOUNT=1000000
